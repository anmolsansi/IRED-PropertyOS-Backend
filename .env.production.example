# Environment variables for production deployment
# Copy to .env and fill in real values

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://propertyos:CHANGE_ME@localhost:5432/propertyos

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── App ──────────────────────────────────────────────────
APP_ENV=production
APP_NAME=IRED-PropertyOS
APP_PORT=3000
APP_CORS_ORIGIN=https://your-domain.com

# ─── Throttler ───────────────────────────────────────────
THROTTLER_TTL=60000
THROTTLER_LIMIT=60

# ─── SMS (twilio | textlocal | console) ──────────────────
SMS_PROVIDER=console
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=PROPERTYOS

# ─── Push Notifications (fcm | console) ──────────────────
PUSH_PROVIDER=console
PUSH_FCM_SERVER_KEY=

# ─── Email ───────────────────────────────────────────────
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# ─── MinIO / S3 ──────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=propertyos-media
MINIO_USE_SSL=false
